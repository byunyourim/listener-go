# 필수
DATABASE_URL=postgres://user:pass@localhost:5432/listener?sslmode=disable
WS_TARGET=ws://localhost:8080/ws

# 선택 (기본값 있음)
RPC_MAX_RETRIES=5
RPC_RETRY_BASE_DELAY_MS=1000
MAX_BLOCKS_PER_POLL=50
BLOCK_DELAY_MS=100
RECONNECT_INTERVAL_MS=3000
DRAIN_TIMEOUT_MS=5000
MANAGER_POLL_INTERVAL_MS=300000
LOG_LEVEL=info
# LOG_PRETTY=true
