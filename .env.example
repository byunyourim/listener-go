# ── 필수 ──────────────────────────────────────────────
DATABASE_URL=postgres://user:pass@localhost:5432/listener?sslmode=disable&pool_max_conns=20
WS_TARGET=ws://localhost:8080/ws

# ── 스캐너 / RPC ──────────────────────────────────────
RPC_MAX_RETRIES=5
RPC_RETRY_BASE_DELAY_MS=1000
MAX_BLOCKS_PER_POLL=50
BLOCK_DELAY_MS=100
MANAGER_POLL_INTERVAL_MS=300000

# ── Publisher / WebSocket ─────────────────────────────
RECONNECT_INTERVAL_MS=3000
DRAIN_TIMEOUT_MS=5000

# Adapter ACK 프로토콜 — Adapter 측 구현 후 true로 전환
PUBLISHER_REQUIRE_ACK=false
PUBLISHER_ACK_TIMEOUT_MS=30000
PUBLISHER_MAX_IN_FLIGHT=100

# ── 감사(audit) 잡 ─────────────────────────────────────
AUDIT_ENABLED=true
AUDIT_INTERVAL_S=3600
AUDIT_WINDOW_BLOCKS=1000
AUDIT_SAFETY_MARGIN=50
AUDIT_SAMPLES_PER_CYCLE=5

# ── 관측성 / HTTP ─────────────────────────────────────
HTTP_ADDR=:8080
BUFFER_STATS_INTERVAL_S=15
LOG_LEVEL=info
# LOG_PRETTY=true

# ── eERC20 (옵션, Phase 1 stub) ───────────────────────
# Production은 KMS/Vault 사용 권장 — env 평문은 dev/staging만.
# EERC_AUDITOR_PRIVATE_KEY=0x...
